# Google OAuth (client credentials for the Google Cloud project that owns
# this app — used for both Sign-in-with-Google and Gmail data access).
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI — used by the todo generator and per-todo AI assistant.
OPENAI_API_KEY=

# Flask session signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Local file search root for the per-todo AI assistant (optional).
LOCAL_SEARCH_ROOT=

# Comma-separated list of pollers to run. Defaults to "gmail,fathom".
# Full set: gmail,fathom,browser_history,system  (last two are macOS-only)
ENABLED_SOURCES=

# Browser used for the (opt-in, macOS-only) browser_history poller.
# Supported: chrome, dia. Defaults to chrome if unset.
# To point at a non-default profile, set BROWSER_HISTORY_PATH instead.
BROWSER=

